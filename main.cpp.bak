#include <QApplication>
#include "StartWindow.h"
#include <ctime>

int main(int argc, char *argv[])
{
    QApplication a(argc, argv);

    srand(time(0));

    a.setStyleSheet(R"(

    QMainWindow, QDialog, QWidget {
        background-color: #0f0f1b;
        color: white;
        font-family: 'Segoe UI', 'Helvetica Neue', sans-serif;
    }

    QLabel {
        color: #e0e0e0;
        font-size: 16px;
    }

    QPushButton {
        background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #e94560, stop:1 #d82b49);
        color: white;
        border-radius: 12px;
        padding: 12px 20px;
        font-size: 16px;
        font-weight: bold;
        border: 2px solid #0f0f1b;
    }

    QPushButton:hover {
        background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #ff4b2b, stop:1 #ff416c);
        border: 2px solid #ff9a9e;
    }

    QPushButton:pressed {
        background-color: #b01b34;
    }

    QLineEdit {
        background-color: #1a1a2e;
        color: #00ffcc;
        padding: 12px;
        border-radius: 10px;
        font-size: 16px;
        border: 2px solid #0f3460;
        font-family: 'Consolas', monospace;
        font-weight: bold;
    }

    QLineEdit:focus {
        border: 2px solid #e94560;
    }

    QTableWidget {
        background-color: #1a1a2e;
        color: white;
        border-radius: 10px;
        gridline-color: #0f3460;
        border: none;
        font-size: 16px;
        selection-background-color: #e94560;
    }

    QHeaderView::section {
        background-color: #0f3460;
        color: #00ffcc;
        padding: 8px;
        font-size: 16px;
        font-weight: bold;
        border: 1px solid #1a1a2e;
    }

    )");

    StartWindow w;
    w.setFixedSize(1024, 768);
    w.show();

    return a.exec();
}